# Mattermost Incoming Webhook URL
# Mattermost → 채널 설정 → 통합 → 수신 웹훅 → 웹훅 추가
MATTERMOST_WEBHOOK_URL=https://your-mattermost.com/hooks/xxxxxxxxxxxxx

# Ollama 설정 (기본값 사용 시 변경 불필요)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:70b

# APM 이상 감지 임계값
APM_CPU_THRESHOLD=80
APM_RESPONSE_TIME_THRESHOLD=2000
APM_DB_CONNECTION_THRESHOLD=80
APM_CHECK_INTERVAL_SECONDS=10

# 로그 감시 설정
LOG_WATCH_INTERVAL_SECONDS=5
LOG_ERROR_KEYWORDS=ERROR,FATAL,Exception,Critical
